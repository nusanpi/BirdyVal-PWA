# CORS - Orígenes permitidos (separados por comas)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500,*

# API key de Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# API key de eBird
EBIRD_API_KEY=

# Ruta al archivo de credenciales de Firebase Admin (service account JSON)
FIREBASE_CREDENTIALS_PATH=environment/firebase-service-account.json

